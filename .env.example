# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Tag Manager (container ID, e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
# Session timeout in seconds (default: 2592000 = 30 days)
# AUTH_SESSION_MAX_AGE=2592000

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=TeamUp <noreply@teamup.ar>

# Mercado Pago (split payments / marketplace) — https://www.mercadopago.com.ar/developers
# Credentials of the TeamUp marketplace application. Organizers connect their own
# account via OAuth; the marketplace_fee of each payment is settled to this app.
MP_CLIENT_ID=your-mercadopago-app-id
MP_CLIENT_SECRET=your-mercadopago-app-secret
# Canonical OAuth redirect URI registered in the Mercado Pago application.
# Mercado Pago requires a single, static URL (no wildcards). In multi-subdomain
# production set this to a fixed host; the OAuth state carries the originating
# subdomain so each organizer is returned to their own subdomain. If unset, the
# current request origin is used (fine for local/single-domain dev).
# MP_REDIRECT_URI=https://teamup.ar/api/mercadopago/callback
# Optional: marketplace app's own access token, used only to instantiate the SDK
# for OAuth token/refresh calls (those authenticate via client_id/secret).
# MP_ACCESS_TOKEN=APP_USR-...
# Optional: secret to validate the x-signature header of incoming webhooks.
# MP_WEBHOOK_SECRET=your-webhook-secret

# Database (NeORM resolves the data source from these variables)
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teamup
DB_USERNAME=postgres
DB_PASSWORD=postgres
